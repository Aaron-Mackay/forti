{
  "name": "forti",
  "version": "0.1.0",
  "engines": {
    "node": ">=24"
  },
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint src",
    "seed": "ts-node prisma/seed.ts",
    "local-db": "psql -h localhost -U postgres -d postgres",
    "test": "vitest run",
    "test:e2e": "start-server-and-test dev http://localhost:3000 'playwright test'",
    "test:e2e:preview": "BASE_URL=https://www.preview.forti-training.co.uk playwright test",
    "rebuild-prisma": "prisma db push && prisma generate",
    "postinstall": "prisma generate",
    "check": "npm run test && npm run lint && npm run build",
    "prepare": "husky",
    "db:reset": "prisma db push --force-reset && prisma generate && ts-node prisma/seed.ts"
  },
  "dependencies": {
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.0",
    "@fontsource/roboto": "^5.2.9",
    "@fullcalendar/core": "^6.1.17",
    "@fullcalendar/interaction": "^6.1.17",
    "@fullcalendar/multimonth": "^6.1.17",
    "@fullcalendar/react": "^6.1.17",
    "@mui/icons-material": "^7.1.1",
    "@mui/material": "^7.1.0",
    "@mui/material-nextjs": "^7.1.1",
    "@mui/x-date-pickers": "^8.8.0",
    "@next-auth/prisma-adapter": "^1.0.7",
    "@prisma/client": "^6.14.0",
    "@use-gesture/react": "^10.3.1",
    "@vercel/analytics": "^1.5.0",
    "@vercel/speed-insights": "^1.2.0",
    "apexcharts": "^5.3.4",
    "date-fns": "^4.1.0",
    "lodash.debounce": "^4.0.8",
    "mailersend": "^2.6.0",
    "next": "^16.1.6",
    "next-auth": "^4.24.11",
    "nextjs-toploader": "^3.9.17",
    "node-fetch": "^3.3.2",
    "node-html-parser": "^7.0.1",
    "react": "^19.0.0",
    "react-apexcharts": "^1.7.0",
    "react-dom": "^19.0.0",
    "swiper": "^12.1.2",
    "typescript-eslint": "^8.34.0",
    "zod": "^4.0.5"
  },
  "overrides": {
    "qs": "^6.15.0"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3",
    "@playwright/test": "1.56.1",
    "@svgr/webpack": "^8.1.0",
    "@testing-library/dom": "^10.4.0",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.3.0",
    "@types/formidable": "^3.4.5",
    "@types/node": "^20.17.32",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@typescript-eslint/eslint-plugin": "^8.34.0",
    "@typescript-eslint/parser": "^8.34.0",
    "@vitejs/plugin-react": "^4.4.1",
    "@vitest/coverage-v8": "^3.2.1",
    "@vitest/ui": "^3.2.1",
    "eslint": "^9.39.3",
    "eslint-config-next": "^16.1.6",
    "fake-indexeddb": "^6.0.1",
    "husky": "^9.1.7",
    "jsdom": "^26.1.0",
    "prisma": "^6.14.0",
    "start-server-and-test": "^2.0.12",
    "ts-node": "^10.9.2",
    "typescript": "^5.8.3",
    "vite-tsconfig-paths": "^5.1.4",
    "vitest": "^3.1.3"
  }
}
