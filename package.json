{
  "name": "forti",
  "version": "0.1.0",
  "private": true,
  "license": "UNLICENSED",
  "engines": {
    "node": "24.x"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "npm run dev --workspace=@forti/web",
    "dev:mobile": "npm run start --workspace=@forti/mobile",
    "build": "npm run build --workspace=@forti/web",
    "start": "npm run start --workspace=@forti/web",
    "lint": "npm run lint --workspace=@forti/web",
    "lint:mobile": "npm run lint --workspace=@forti/mobile",
    "test": "npm run test --workspace=@forti/web",
    "test:mobile": "npm run test --workspace=@forti/mobile",
    "test:e2e": "npm run test:e2e --workspace=@forti/web",
    "api:index": "npm run api:index --workspace=@forti/web",
    "api:index:check": "npm run api:index:check --workspace=@forti/web",
    "seed": "npm run seed --workspace=@forti/web",
    "seed:demo": "npm run seed:demo --workspace=@forti/web",
    "recalculate-e1rm": "npm run recalculate-e1rm --workspace=@forti/web",
    "rebuild-prisma": "npm run rebuild-prisma --workspace=@forti/web",
    "merge-exercises": "npm run merge-exercises --workspace=@forti/web",
    "local-db": "npm run local-db --workspace=@forti/web",
    "knip": "npm run knip --workspace=@forti/web",
    "check:mobile": "npm run check --workspace=@forti/mobile",
    "check": "npm run check --workspace=@forti/web",
    "prepare": "husky"
  },
  "devDependencies": {
    "husky": "^9.1.7"
  },
  "overrides": {
    "qs": "^6.15.0",
    "@hono/node-server": "^1.19.13",
    "axios": "^1.15.0",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "@types/react": "~19.1.0",
    "@types/react-dom": "~19.1.0"
  }
}
