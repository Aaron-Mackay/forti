{
  "name": "forti",
  "version": "0.1.0",
  "engines": {
    "node": ">=24"
  },
  "private": true,
  "scripts": {
    "dev": "next dev",
    "dev:share": "./scripts/dev-share.sh",
    "dev:share:kill": "./scripts/dev-share-kill.sh",
    "build": "next build",
    "postbuild": "if [ \"$VERCEL_ENV\" != \"\" ]; then prisma migrate deploy; fi",
    "postinstall": "prisma generate",
    "start": "next start",
    "lint": "eslint src tests",
    "seed": "ts-node prisma/seed.ts",
    "recalculate-e1rm": "ts-node scripts/recalculate-e1rm.ts",
    "seed:demo": "ts-node prisma/seed-demo.ts",
    "local-db": "psql -h localhost -U postgres -d postgres",
    "test": "vitest run",
    "test:e2e": "start-server-and-test dev http://localhost:3000 'playwright test'",
    "test:e2e:preview": "BASE_URL=https://www.preview.forti-training.co.uk playwright test",
    "rebuild-prisma": "prisma migrate dev --name \"\" && prisma generate",
    "check": "npm run test && npm run lint && npm run build",
    "knip": "knip",
    "prepare": "husky"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.82.0",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.0",
    "@fontsource/roboto": "^5.2.10",
    "@fullcalendar/core": "^6.1.17",
    "@fullcalendar/interaction": "^6.1.20",
    "@fullcalendar/multimonth": "^6.1.20",
    "@fullcalendar/react": "^6.1.20",
    "@fullcalendar/rrule": "^6.1.20",
    "@mui/icons-material": "^7.3.9",
    "@mui/material": "^7.1.0",
    "@mui/material-nextjs": "^7.3.9",
    "@mui/x-date-pickers": "^8.27.2",
    "@next-auth/prisma-adapter": "^1.0.7",
    "@prisma/adapter-pg": "^7.6.0",
    "@prisma/client": "^7.6.0",
    "@types/web-push": "^3.6.4",
    "@use-gesture/react": "^10.3.1",
    "@vercel/analytics": "^2.0.1",
    "@vercel/blob": "^2.3.3",
    "@vercel/speed-insights": "^2.0.0",
    "apexcharts": "^5.10.5",
    "date-fns": "^4.1.0",
    "mailersend": "^2.8.0",
    "next": "^16.2.2",
    "next-auth": "^4.24.11",
    "nextjs-toploader": "^3.9.17",
    "react": "^19.2.4",
    "react-apexcharts": "^2.1.0",
    "react-dom": "^19.2.4",
    "rrule": "^2.8.1",
    "swiper": "^12.1.3",
    "web-push": "^3.6.7",
    "zod": "^4.3.6"
  },
  "overrides": {
    "qs": "^6.15.0"
  },
  "devDependencies": {
    "@playwright/test": "1.59.1",
    "@svgr/webpack": "^8.1.0",
    "@testing-library/dom": "^10.4.0",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^25.5.2",
    "@types/pg": "^8.11.14",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/coverage-v8": "^4.1.2",
    "@vitest/ui": "^4.1.2",
    "eslint": "^9.39.3",
    "eslint-config-next": "^16.2.2",
    "eslint-plugin-playwright": "^2.10.1",
    "fake-indexeddb": "^6.0.1",
    "husky": "^9.1.7",
    "jsdom": "^29.0.2",
    "knip": "^6.3.0",
    "pg": "^8.16.3",
    "prisma": "^7.6.0",
    "start-server-and-test": "^3.0.0",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.2",
    "vite-tsconfig-paths": "^6.1.1",
    "vitest": "^4.1.2"
  }
}
