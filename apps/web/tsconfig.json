{
  "compilerOptions": {
    "target": "ES6", // JavaScript version output
    "types": [
      "node",
      "vitest/globals",
      "@testing-library/jest-dom"
    ],
    "module": "ESNext", // Next.js expects modern ESM module output for type resolution
    "lib": [
      "DOM",
      "esnext"
    ], // Include modern JS features
    "esModuleInterop": true, // Allow default imports
    "skipLibCheck": true, // Skip type checking of declaration files
    "strict": true, // Enable all strict type-checking options
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true, // Allows importing JSON files
    "outDir": "./dist", // Output directory for compiled JS files
    "rootDir": ".", // Root directory of your TypeScript files
    "moduleResolution": "bundler", // Resolve package exports the way Next.js and modern ESM packages expect
    "baseUrl": ".", // Base directory for resolving non-relative paths
    "paths": {
      "@/*": [
        "src/*"
      ],
      "@lib/*": [
        "src/lib/*"
      ]
    },
    "allowJs": true,
    "noEmit": true,
    "incremental": true,
    "isolatedModules": true,
    "jsx": "react-jsx",
    "plugins": [
      {
        "name": "next"
      }
    ]
  },
  "ts-node": {
    "require": ["tsconfig-paths/register"]
  },
  "include": [
    "svgr.d.ts",
    "prisma.config.ts",
    "prisma/seed.ts",
    // Include all files in src/
    "src/**/*",
    // Include the seed file if it’s outside src,
    ".next/types/**/*.ts",
    "node_modules/vitest/globals.d.ts",
    ".next/dev/types/**/*.ts"
  ],
  "exclude": [
    "node_modules", // Exclude node_modules from compilation
    "dist" // Exclude dist folder
  ]
}
