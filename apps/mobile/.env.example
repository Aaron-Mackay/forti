# Required: base URL of the Forti web API (no trailing slash).
#   Local dev (Expo Go): use your machine's LAN IP, e.g. http://192.168.1.10:3000
#   Tunnel (`expo start --tunnel`): use https://<tunnel-id>.exp.direct
#   Staging/prod: https://www.forti-training.co.uk
EXPO_PUBLIC_API_BASE_URL=

# Required for Google sign-in (one of the platform IDs must match the runtime).
# Create OAuth client IDs in Google Cloud Console; iOS uses bundle id, Android
# uses package name + SHA-1, web uses an authorized redirect URI.
EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID=
EXPO_PUBLIC_GOOGLE_ANDROID_CLIENT_ID=
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=
