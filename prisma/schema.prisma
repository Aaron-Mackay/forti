// schema.prisma

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  name          String
  image         String?
  emailVerified DateTime?

  // NextAuth required
  accounts Account[]
  sessions Session[]

  plans             Plan[]   @relation("OwnedPlans")
  activePlanId      Int?
  activePlan        Plan?    @relation("ActivePlan", fields: [activePlanId], references: [id], onDelete: SetNull)
  events            Event[]
  userExerciseNotes UserExerciseNote[]
  dayMetrics        DayMetric[]

  settings Json?

  // self relation (coach <-> clients)
  coachId String?
  coach   User?   @relation("CoachClients", fields: [coachId], references: [id])
  clients User[]  @relation("CoachClients")

  // coach linking system
  coachCode             String?        @unique // 6-digit string, generated once on activation
  coachLogoUrl          String?
  sentCoachRequest      CoachRequest?  @relation("ClientRequests")
  receivedCoachRequests CoachRequest[] @relation("CoachRequests")

  aiUsageLogs               AiUsageLog[]
  weeklyCheckIns            WeeklyCheckIn[]
  pushSubscriptions         PushSubscription[]
  supplements               Supplement[]
  notifications             Notification[]
  createdExercises          Exercise[]                 @relation("UserCreatedExercises")
  libraryAssets             LibraryAsset[]
  coachExerciseDescriptions CoachExerciseDescription[] @relation("CoachExerciseDescriptions")
  learningPlans             LearningPlan[]             @relation("CoachLearningPlans")
  learningAssignments       LearningPlanAssignment[]   @relation("ClientAssignments")
  targetTemplates           TargetTemplate[]
}

enum CoachRequestStatus {
  Pending
  Rejected
}

model CoachRequest {
  id        Int                @id @default(autoincrement())
  clientId  String             @unique // one request per user at a time
  client    User               @relation("ClientRequests", fields: [clientId], references: [id], onDelete: Cascade)
  coachId   String
  coach     User               @relation("CoachRequests", fields: [coachId], references: [id], onDelete: Cascade)
  status    CoachRequestStatus @default(Pending)
  createdAt DateTime           @default(now())

  @@index([coachId, status, createdAt(sort: Desc)])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

enum ExerciseCategory {
  resistance
  cardio
}

enum EventType {
  BlockEvent
  CustomEvent
}

enum BlockSubtype {
  Bulk
  Cut
  Maintenance
  Deload
  Prep
  Refeed
  Custom
}

model Event {
  id                  Int           @id @default(autoincrement())
  user                User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId              String
  name                String
  description         String?
  startDate           DateTime      @db.Date // only the date part matters
  endDate             DateTime      @db.Date // inclusive
  customColor         String?
  eventType           EventType
  blockSubtype        BlockSubtype?
  recurrenceFrequency String? // "DAILY" | "WEEKLY" | "MONTHLY" | "YEARLY"; null = not recurring
  recurrenceEnd       DateTime?     @db.Date // inclusive end date of recurrence; null = forever

  @@index([userId, startDate, endDate])
}

model DayMetric {
  id        Int      @id @default(autoincrement())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  weight    Float?
  steps     Int?
  sleepMins Int?
  calories  Int?
  protein   Int?
  carbs     Int?
  fat       Int?
  date      DateTime @db.Date

  // Custom user-defined metrics: { "<uuid>": { value: Float, target: Float } }
  customMetrics Json?

  @@unique([userId, date])
}

model TargetTemplate {
  id              Int                @id @default(autoincrement())
  userId          String
  user            User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  effectiveFrom   DateTime           @db.Date // Always a Monday (ISO week start)
  createdAt       DateTime           @default(now())
  // Uniform daily targets (same every day of the week)
  stepsTarget     Int?
  sleepMinsTarget Int?
  days            TargetTemplateDay[]

  @@unique([userId, effectiveFrom])
}

model TargetTemplateDay {
  id             Int            @id @default(autoincrement())
  templateId     Int
  template       TargetTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)
  dayOfWeek      Int            // ISO: 1=Mon … 7=Sun
  // Per-day macro targets (may vary by training/rest day)
  caloriesTarget Int?
  proteinTarget  Int?
  carbsTarget    Int?
  fatTarget      Int?

  @@unique([templateId, dayOfWeek])
}

model Plan {
  id          Int     @id @default(autoincrement())
  user        User    @relation("OwnedPlans", fields: [userId], references: [id], onDelete: Cascade)
  userId      String
  order       Int
  name        String
  description String?
  lastActivityDate DateTime? @db.Date
  weeks       Week[]
  activeForUsers User[] @relation("ActivePlan")

  @@unique([userId, order])
  @@index([userId])
}

model Week {
  id       Int       @id @default(autoincrement())
  order    Int
  plan     Plan      @relation(fields: [planId], references: [id], onDelete: Cascade)
  planId   Int
  workouts Workout[]

  @@unique([planId, order])
  @@index([planId])
}

model Workout {
  id            Int               @id @default(autoincrement())
  order         Int
  week          Week              @relation(fields: [weekId], references: [id], onDelete: Cascade)
  weekId        Int
  name          String
  notes         String?
  exercises     WorkoutExercise[]
  dateCompleted DateTime?

  @@unique([weekId, order])
  @@index([weekId])
}

model Exercise {
  id                 Int                        @id @default(autoincrement())
  name               String
  category           ExerciseCategory?
  description        String?
  equipment          String[]                   @default([])
  primaryMuscles     String[]                   @default([])
  secondaryMuscles   String[]                   @default([])
  workoutLinks       WorkoutExercise[]
  substitutedByLinks WorkoutExercise[]          @relation("SubstitutedExercises")
  UserExerciseNote   UserExerciseNote[]
  createdByUserId    String?
  createdByUser      User?                      @relation("UserCreatedExercises", fields: [createdByUserId], references: [id], onDelete: SetNull)
  coachDescriptions  CoachExerciseDescription[]

  @@unique([name, category, createdByUserId], name: "name_category_user")
  @@index([createdByUserId])
}

model WorkoutExercise {
  id               Int           @id @default(autoincrement())
  workout          Workout       @relation(fields: [workoutId], references: [id], onDelete: Cascade)
  workoutId        Int
  exercise         Exercise      @relation(fields: [exerciseId], references: [id])
  exerciseId       Int
  order            Int
  restTime         String?
  repRange         String?
  notes            String?
  targetRpe        Float? // prescribed RPE target for this exercise
  targetRir        Int? // prescribed RIR target for this exercise
  sets             ExerciseSet[]
  cardioDuration   Float? // minutes
  cardioDistance   Float? // km
  cardioResistance Float? // average resistance / incline
  substitutedForId Int? // original Exercise.id before substitution
  substitutedFor   Exercise?     @relation("SubstitutedExercises", fields: [substitutedForId], references: [id])
  isAdded          Boolean       @default(false) // true if added during workout (not in original plan)
  isBfr            Boolean       @default(false) // true if this is a BFR (Blood Flow Restriction) exercise

  @@unique([workoutId, order])
}

model ExerciseSet {
  id                Int             @id @default(autoincrement())
  order             Int
  workoutExercise   WorkoutExercise @relation(fields: [workoutExerciseId], references: [id], onDelete: Cascade)
  workoutExerciseId Int
  reps              Int?
  weight            Float?
  // Estimated 1-rep max (Epley formula: weight * (1 + reps/30)). Computed on write.
  e1rm              Float?
  // Perceived effort — only one should be set per set depending on user preference
  rpe               Float?
  rir               Int?
  isDropSet         Boolean         @default(false)
  parentSetId       Int?
  parentSet         ExerciseSet?    @relation("DropSetParent", fields: [parentSetId], references: [id], onDelete: SetNull)
  childSets         ExerciseSet[]   @relation("DropSetParent")

  @@unique([workoutExerciseId, order])
}

model UserExerciseNote {
  id         Int      @id @default(autoincrement())
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId     String
  exercise   Exercise @relation(fields: [exerciseId], references: [id], onDelete: Cascade)
  exerciseId Int
  note       String

  @@unique([userId, exerciseId])
}

model CoachExerciseDescription {
  id          Int      @id @default(autoincrement())
  coachId     String
  coach       User     @relation("CoachExerciseDescriptions", fields: [coachId], references: [id], onDelete: Cascade)
  exerciseId  Int
  exercise    Exercise @relation(fields: [exerciseId], references: [id], onDelete: Cascade)
  description String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([coachId, exerciseId])
  @@index([coachId])
}

model WeeklyCheckIn {
  id            Int       @id @default(autoincrement())
  userId        String
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  weekStartDate DateTime  @db.Date // the Monday of the check-in week (0 = Mon convention)
  completedAt   DateTime? // null = not yet submitted

  // Subjective ratings (1–5)
  energyLevel     Int?
  moodRating      Int?
  stressLevel     Int?
  sleepQuality    Int?
  recoveryRating  Int?
  adherenceRating Int?

  // Training counts
  completedWorkouts Int?
  plannedWorkouts   Int?

  // Free text
  weekReview    String?
  coachMessage  String?
  goalsNextWeek String?

  // Coach feedback (written by coach)
  coachNotes      String?
  coachReviewedAt DateTime?

  // Progress photos (uploaded via /api/check-in/photos)
  frontPhotoUrl String?
  backPhotoUrl  String?
  sidePhotoUrl  String?

  @@unique([userId, weekStartDate])
}

model PushSubscription {
  id        Int      @id @default(autoincrement())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  endpoint  String   @unique
  p256dh    String
  auth      String
  createdAt DateTime @default(now())

  @@index([userId])
}

model AiUsageLog {
  id        Int      @id @default(autoincrement())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId    String
  createdAt DateTime @default(now())

  @@index([userId, createdAt])
}

model Supplement {
  id        Int       @id @default(autoincrement())
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  name      String
  startDate DateTime  @db.Date
  endDate   DateTime? @db.Date

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  versions  SupplementVersion[]

  @@index([userId])
}

model SupplementVersion {
  id            Int        @id @default(autoincrement())
  supplementId  Int
  supplement    Supplement @relation(fields: [supplementId], references: [id], onDelete: Cascade)
  effectiveFrom DateTime   @db.Date
  dosage        String
  frequency     String
  notes         String?

  @@unique([supplementId, effectiveFrom])
  @@index([supplementId, effectiveFrom])
}

enum LibraryAssetType {
  LINK
  DOCUMENT
  IMAGE
  VIDEO
}

model LibraryAsset {
  id           String           @id @default(cuid())
  title        String
  description  String?
  type         LibraryAssetType
  url          String?
  isCoachAsset Boolean          @default(false)
  userId       String
  user         User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt

  learningPlanSteps LearningPlanStep[]

  @@index([userId])
}

enum NotificationType {
  CheckInSubmitted
  CoachFeedback
  CoachRequestReceived
  CoachRequestAccepted
  LearningPlanStepDelivered
}

model Notification {
  id        Int              @id @default(autoincrement())
  userId    String
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      NotificationType
  title     String
  body      String
  url       String
  readAt    DateTime?
  createdAt DateTime         @default(now())

  @@index([userId, readAt])
  @@index([userId, createdAt(sort: Desc)])
}

model LearningPlan {
  id          Int                      @id @default(autoincrement())
  coachId     String
  coach       User                     @relation("CoachLearningPlans", fields: [coachId], references: [id], onDelete: Cascade)
  title       String
  description String?
  steps       LearningPlanStep[]
  assignments LearningPlanAssignment[]
  createdAt   DateTime                 @default(now())
  updatedAt   DateTime                 @updatedAt

  @@index([coachId])
}

model LearningPlanStep {
  id        Int           @id @default(autoincrement())
  planId    Int
  plan      LearningPlan  @relation(fields: [planId], references: [id], onDelete: Cascade)
  order     Int
  dayOffset Int // days after assignment startDate to deliver
  title     String
  body      String        @db.Text
  assetId   String?
  asset     LibraryAsset? @relation(fields: [assetId], references: [id], onDelete: SetNull)

  @@unique([planId, order])
  @@index([planId])
}

model LearningPlanAssignment {
  id           Int          @id @default(autoincrement())
  planId       Int
  plan         LearningPlan @relation(fields: [planId], references: [id], onDelete: Cascade)
  clientId     String
  client       User         @relation("ClientAssignments", fields: [clientId], references: [id], onDelete: Cascade)
  startDate    DateTime     @db.Date
  // { "[stepId]": { notifiedAt: string | null, completedAt: string | null } }
  stepProgress Json?
  createdAt    DateTime     @default(now())

  @@unique([planId, clientId])
  @@index([clientId, startDate(sort: Desc)])
}
