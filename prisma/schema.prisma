// schema.prisma

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                String             @id @default(cuid())
  email             String             @unique
  name              String
  image             String?
  emailVerified     DateTime?

  // NextAuth required
  accounts          Account[]
  sessions          Session[]

  plans             Plan[]
  events            Event[]
  userExerciseNotes UserExerciseNote[]
  dayMetrics        DayMetric[]

  settings          Json?

  // self relation (coach <-> clients)
  coachId           String?
  coach             User?              @relation("CoachClients", fields: [coachId], references: [id])
  clients          User[]             @relation("CoachClients")

  aiUsageLogs       AiUsageLog[]
}

model Account {
  id                 String  @id @default(cuid())
  userId             String
  type               String
  provider           String
  providerAccountId  String
  refresh_token      String?
  access_token       String?
  expires_at         Int?
  token_type         String?
  scope              String?
  id_token           String?
  session_state      String?
  user               User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

enum ExerciseCategory {
  resistance
  cardio
}

enum EventType {
  BlockEvent
  CustomEvent
}

enum BlockSubtype {
  Bulk
  Cut
  Maintenance
  Deload
  Prep
  Refeed
  Custom
}

model Event {
  id           Int           @id @default(autoincrement())
  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId       String
  name         String
  description  String?
  startDate    DateTime      @db.Date // only the date part matters
  endDate      DateTime      @db.Date // inclusive
  customColor  String?
  eventType    EventType
  blockSubtype BlockSubtype?

  @@index([userId])
  @@index([startDate, endDate])
}

model DayMetric {
  id        Int      @id @default(autoincrement())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  weight    Float?
  steps     Int?
  sleepMins Int?
  calories  Int?
  protein   Int?
  carbs     Int?
  fat       Int?
  date      DateTime @db.Date

  @@unique([userId, date])
}

model Plan {
  id          Int     @id @default(autoincrement())
  user        User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId      String
  order       Int
  name        String
  description String?
  weeks       Week[]

  @@unique([userId, order])
}

model Week {
  id      Int      @id @default(autoincrement())
  order   Int
  plan    Plan     @relation(fields: [planId], references: [id], onDelete: Cascade)
  planId  Int
  workouts Workout[]

  @@unique([planId, order])
}

model Workout {
  id            Int               @id @default(autoincrement())
  order         Int
  week          Week              @relation(fields: [weekId], references: [id], onDelete: Cascade)
  weekId        Int
  name          String
  notes         String?
  exercises     WorkoutExercise[]
  dateCompleted DateTime?

  @@unique([weekId, order])
}

model Exercise {
  id               Int                @id @default(autoincrement())
  name             String
  category         ExerciseCategory?
  description      String?
  equipment        String[]           @default([])
  primaryMuscles   String[]           @default([])
  secondaryMuscles String[]           @default([])
  workoutLinks       WorkoutExercise[]
  substitutedByLinks WorkoutExercise[] @relation("SubstitutedExercises")
  UserExerciseNote   UserExerciseNote[]

  @@unique([name, category], name: "name_category")
}

model WorkoutExercise {
  id               Int           @id @default(autoincrement())
  workout          Workout       @relation(fields: [workoutId], references: [id], onDelete: Cascade)
  workoutId        Int
  exercise         Exercise      @relation(fields: [exerciseId], references: [id])
  exerciseId       Int
  order            Int
  restTime         String?
  repRange         String?
  notes            String?
  sets             ExerciseSet[]
  cardioDuration   Float?        // minutes
  cardioDistance   Float?        // km
  cardioResistance Float?        // average resistance / incline
  substitutedForId Int?          // original Exercise.id before substitution
  substitutedFor   Exercise?     @relation("SubstitutedExercises", fields: [substitutedForId], references: [id])
  isAdded          Boolean       @default(false) // true if added during workout (not in original plan)

  @@unique([workoutId, order])
}

model ExerciseSet {
  id                Int             @id @default(autoincrement())
  order             Int
  workoutExercise   WorkoutExercise @relation(fields: [workoutExerciseId], references: [id], onDelete: Cascade)
  workoutExerciseId Int
  reps              Int?
  weight            Float?
  // Estimated 1-rep max (Epley formula: weight * (1 + reps/30)). Computed on write.
  e1rm              Float?

  @@unique([workoutExerciseId, order])
}

model UserExerciseNote {
  id         Int      @id @default(autoincrement())
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId     String
  exercise   Exercise @relation(fields: [exerciseId], references: [id], onDelete: Cascade)
  exerciseId Int
  note       String

  @@unique([userId, exerciseId])
  @@index([userId])
  @@index([exerciseId])
}

model AiUsageLog {
  id        Int      @id @default(autoincrement())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId    String
  createdAt DateTime @default(now())

  @@index([userId, createdAt])
}
